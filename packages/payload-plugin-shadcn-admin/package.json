{
  "name": "payload-plugin-shadcn-admin",
  "version": "0.0.1",
  "description": "Reusable shadcn/ui-based admin chrome and server-driven DataTable for Payload CMS",
  "license": "MIT",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "import": "./dist/exports/client.js",
      "types": "./dist/exports/client.d.ts",
      "default": "./dist/exports/client.js"
    },
    "./rsc": {
      "import": "./dist/exports/rsc.js",
      "types": "./dist/exports/rsc.d.ts",
      "default": "./dist/exports/rsc.js"
    },
    "./types": {
      "import": "./dist/exports/types.js",
      "types": "./dist/exports/types.d.ts",
      "default": "./dist/exports/types.js"
    },
    "./styles.css": "./dist/styles.css",
    "./themes.css": "./dist/themes.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run copyfiles && pnpm run build:types && pnpm run build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "copyfiles": "copyfiles -u 1 \"src/**/*.css\" dist/",
    "clean": "rimraf dist *.tsbuildinfo",
    "dev": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths --watch",
    "typecheck": "tsc --noEmit",
    "check:internals": "node scripts/check-payload-internals.mjs"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "qs-esm": "^8.0.1",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "@payloadcms/next": ">=3.84 <3.90",
    "@payloadcms/richtext-lexical": ">=3.84 <3.90",
    "@payloadcms/translations": ">=3.84 <3.90",
    "@payloadcms/ui": ">=3.84 <3.90",
    "next": ">=15 <17",
    "payload": ">=3.84 <3.90",
    "payload-plugin-shadcn-ui": ">=0.0.1",
    "radix-ui": "^1.4.3",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "peerDependenciesMeta": {
    "@payloadcms/richtext-lexical": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/translations": "^3.85.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "copyfiles": "^2.4.1",
    "payload-plugin-shadcn-ui": "workspace:*",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3"
  }
}
