{
  "name": "payload-plugin-shadcn-ui",
  "version": "0.0.1",
  "description": "shadcn/ui primitives + doc-form extension hooks used by payload-plugin-shadcn-admin and by feature plugins (menus/products/seo). Lets feature plugins depend on the UI surface without taking a runtime dep on the admin replacement.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./themes.css": "./dist/themes.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run copyfiles && pnpm run build:types && pnpm run build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "copyfiles": "copyfiles -u 1 \"src/**/*.css\" dist/",
    "clean": "rimraf dist *.tsbuildinfo",
    "dev": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths --watch",
    "typecheck": "tsc --noEmit",
    "print-source": "node scripts/print-source.mjs",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^1.16.0",
    "react-day-picker": "^9.4.4",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "@payloadcms/ui": ">=3.84 <3.90",
    "@payloadcms/translations": ">=3.84 <3.90",
    "next": ">=15 <17",
    "payload": ">=3.84 <3.90",
    "radix-ui": "^1.4.3",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "devDependencies": {
    "@payloadcms/translations": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.0",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "copyfiles": "^2.4.1",
    "rimraf": "^5.0.0",
    "payload": "^3.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "6.0.3"
  }
}
