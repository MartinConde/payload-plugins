{
  "name": "payload-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "In-house Payload CMS plugins (shadcn-admin, seo, menus) — pnpm workspace.",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
